---
# Error documents
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html

# Security basics
Options -Indexes
ServerSignature Off
LimitRequestBody 104857600
AddDefaultCharset UTF-8

# Protect .htaccess
<Files .htaccess>
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>

# Block TRACE and TRACK methods
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)
  RewriteRule .* - [F]
</IfModule>

# Block common query string injection attempts
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{QUERY_STRING} (\"|%22).*(<|>|%3) [NC,OR]
  RewriteCond %{QUERY_STRING} (javascript:).*(\;) [NC,OR]
  RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3) [NC,OR]
  RewriteCond %{QUERY_STRING} (\;|'|\"|%22).*(union|select|insert|drop|update|md5|benchmark) [NC,OR]
  RewriteCond %{QUERY_STRING} (base64_encode|localhost) [NC,OR]
  RewriteCond %{QUERY_STRING} (boot\.ini|etc/passwd) [NC,OR]
  RewriteCond %{QUERY_STRING} (GLOBALS|REQUEST)(=|\[|%) [NC]
  RewriteRule .* - [F]
</IfModule>

# Block suspicious request strings
<IfModule mod_alias.c>
  RedirectMatch 403 (eval\(|base64_encode|proc/self/environ)
  RedirectMatch 403 \.(exe|dll|mdb|sql|ini|rar|cfg)$
</IfModule>

# Block known bad user agents
<IfModule mod_setenvif.c>
  SetEnvIfNoCase User-Agent (binlar|casper|cmsworldmap|comodo|diavol|feedfinder|jakarta|kmccrew|nutch|planetwork|purebot|pycurl|skygrid|sucker|turnit|vikspider|zmeu) keep_out
  <limit GET POST PUT>
    Order Allow,Deny
    Allow from all
    Deny from env=keep_out
  </limit>
</IfModule>

# Redirect WordPress category and tag archives to 404
RedirectMatch 404 ^/category/?$
RedirectMatch 404 ^/tag/?$

# MIME types
AddType image/svg+xml svg svgz
AddType video/mp4 mp4

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>
